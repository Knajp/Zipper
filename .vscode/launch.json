{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug",
      "type": "cppdbg",
      "request": "launch",
      "preLaunchTask": "buildDebug",
      "program": "${workspaceRoot}/bin/Debug/NewEngine",
      "cwd": "${workspaceFolder}",
      "externalConsole": false,
      "args": [],
      "logging": {
        "engineLogging": true,
        "trace": true,
      "traceResponse": true
      }
    },
    {
      "name": "Release",
      "type": "cppdbg",
      "request": "launch",
      "preLaunchTask": "buildRelease",
      "program": "${workspaceRoot}/bin/Release/NewEngine",
      "cwd": "${workspaceFolder}",
      "externalConsole": false,
      "args": []
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "/home/lenovo/Documents/cpp/NewEngine/src",
      "program": "/home/lenovo/Documents/cpp/NewEngine/bin/Debug/NewEngine",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}